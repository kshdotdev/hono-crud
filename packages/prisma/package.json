{
  "name": "@hono-crud/prisma",
  "version": "0.1.14",
  "description": "Prisma CRUD adapter for hono-crud",
  "author": "Kauan Guesser <contato@kauan.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kshdotdev/hono-crud.git",
    "directory": "packages/prisma"
  },
  "homepage": "https://github.com/kshdotdev/hono-crud#readme",
  "bugs": {
    "url": "https://github.com/kshdotdev/hono-crud/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsup",
    "lint": "biome check src/"
  },
  "keywords": [
    "hono",
    "crud",
    "prisma",
    "adapter"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@prisma/adapter-pg": ">=5.0.0",
    "@prisma/client": ">=5.0.0",
    "fastest-levenshtein": ">=1.0.0",
    "hono": ">=4.11.7 <5",
    "hono-crud": "workspace:^",
    "pluralize": ">=8.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "@prisma/adapter-pg": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "pluralize": {
      "optional": true
    },
    "fastest-levenshtein": {
      "optional": true
    }
  },
  "devDependencies": {
    "@prisma/client": "^7.2.0",
    "@types/pluralize": "^0.0.33",
    "fastest-levenshtein": "^1.0.16",
    "hono": "^4.11.7",
    "hono-crud": "workspace:*",
    "pluralize": "^8.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "zod": "^4.3.5"
  }
}
