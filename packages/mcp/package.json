{
  "name": "@hono-crud/mcp",
  "version": "0.1.9",
  "description": "Auto-generate Model Context Protocol (MCP) tools from hono-crud resources",
  "author": "Kauan Guesser <contato@kauan.net>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kshdotdev/hono-crud.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/kshdotdev/hono-crud#readme",
  "bugs": {
    "url": "https://github.com/kshdotdev/hono-crud/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .tsup",
    "lint": "biome check src/"
  },
  "keywords": [
    "hono",
    "crud",
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "tools"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "hono-crud": "workspace:*",
    "@hono/mcp": "^0.3.0"
  },
  "peerDependencies": {
    "hono": ">=4.11.7 <5",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "zod": ">=4"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.11.4",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "zod": "^4.3.5"
  }
}
